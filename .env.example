# DIP Bundestag API — Register at https://dip.bundestag.de
# A demo key is publicly available for testing
DIP_API_KEY=your_dip_api_key_here

# Groq API — Free key at https://groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: override defaults
DIP_API_BASE_URL=https://search.dip.bundestag.de/api/v1
GROQ_MODEL=llama-3.3-70b-versatile
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS=5
